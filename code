let fcCards = [];
let fcIdx = 0;

function renderFlashcardSetup() {
    const grid = document.getElementById("fc-topic-grid");
    grid.innerHTML = `<div class="fc-topic-btn" onclick="startFC('all')"><div style="font-size:2rem">📚</div><div style="font-weight:bold; margin-top:10px;">Alle Themen mixen</div></div>`;
    COURSE_DATA.forEach(t => {
        let count = 0;
        t.categories.forEach(c => c.lessons.forEach(l => { if(l.content.flashcards) count += l.content.flashcards.length; }));
        if(count > 0) {
            grid.innerHTML += `<div class="fc-topic-btn" onclick="startFC('${t.id}')"><div style="font-size:2rem">${t.icon}</div><div style="font-weight:bold; margin-top:10px;">${t.title}</div><div style="font-size:0.8rem; color:var(--text-tertiary)">${count} Karten</div></div>`;
        }
    });
}

function startFC(topicId) {
    fcCards = []; fcIdx = 0;
    COURSE_DATA.forEach(t => {
        if(topicId === 'all' || t.id === topicId) {
            t.categories.forEach(c => c.lessons.forEach(l => {
                if(l.content.flashcards) fcCards.push(...l.content.flashcards);
            }));
        }
    });
    fcCards.sort(() => Math.random() - 0.5); // Shuffle
    document.getElementById("fc-setup-view").style.display = "none";
    document.getElementById("fc-active-view").style.display = "flex";
    updateFC();
}

function stopFlashcards() {
    document.getElementById("fc-setup-view").style.display = "block";
    document.getElementById("fc-active-view").style.display = "none";
}

function flipCard() { document.getElementById("fc-card").classList.toggle("is-flipped"); }

function nextCard() {
    document.getElementById("fc-card").classList.remove("is-flipped");
    setTimeout(() => {
        fcIdx++;
        if(fcIdx >= fcCards.length) { showToast("Deck abgeschlossen!", "success"); fcIdx=0; fcCards.sort(() => Math.random() - 0.5); }
        updateFC();
    }, 200);
}

function updateFC() {
    document.getElementById("fc-question").innerHTML = fcCards[fcIdx].q;
    document.getElementById("fc-answer").innerHTML = fcCards[fcIdx].a;
}

