function getCurrentLlmSettings() {
    const provider = document.getElementById("chatProvider")?.value || Storage.data.llm.provider;
    const modelInput = document.getElementById("chatModel")?.value?.trim();
    const apiKeyInput = document.getElementById("chatApiKey")?.value?.trim();
    return {
        provider,
        model: modelInput || (provider === "gemini" ? "gemini-2.0-flash" : "gpt-4.1-mini"),
        apiKey: apiKeyInput || Storage.data.llm.apiKey
    };
}

function syncLlmSettingsToUi() {
    const settings = Storage.data.llm;
    const ids = ["chatProvider", "llmProvider", "chatModel", "llmModel", "chatApiKey", "llmApiKey"];
    ids.forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        if (id.includes("Provider")) el.value = settings.provider;
        if (id.includes("Model")) el.value = settings.model;
        if (id.includes("ApiKey")) el.value = settings.apiKey;
    });
}

function saveLlmSettingsFromStats() {
    const provider = document.getElementById("llmProvider").value;
    const apiKey = document.getElementById("llmApiKey").value.trim();
    const modelValue = document.getElementById("llmModel").value.trim();
    Storage.data.llm = { provider, apiKey, model: modelValue || (provider === "gemini" ? "gemini-2.0-flash" : "gpt-4.1-mini") };
    Storage.save();
    syncLlmSettingsToUi();
    showToast("KI-Einstellungen gespeichert.", "success");
}

function applySettingsToChat() {
    syncLlmSettingsToUi();
    showToast("Chat-Einstellungen aus App-Settings geladen.", "info");
}

function setAiChatStatus(message) { document.getElementById("aiChatStatus").textContent = message; }

function renderAiChatMessages() {
    const box = document.getElementById("aiChatMessages");
    const visibleMessages = aiChatState.messages.filter(m => m.role !== "system");
    box.innerHTML = visibleMessages.map(m => `<div class="ai-chat-msg ${m.role}">${escapeHtml(m.content)}</div>`).join("");
    box.scrollTop = box.scrollHeight;
}

function openAiChat(context) {
    aiChatState = {
        contextType: context.type,
        contextTitle: context.title,
        contextBody: context.body,
        messages: [{ role: "assistant", content: `Frag mich alles zu „${context.title}“. Ich antworte im IHK-Prüfungsstil.` }]
    };
    document.getElementById("aiChatContext").textContent = `Kontext: ${context.type} • ${context.title}`;
    document.getElementById("aiChatInput").value = "";
    renderAiChatMessages();
    setAiChatStatus("Bereit");
    syncLlmSettingsToUi();
    document.getElementById("aiChatModal").classList.add("open");
    document.getElementById("aiChatModal").setAttribute("aria-hidden", "false");
}

function closeAiChat() {
    document.getElementById("aiChatModal").classList.remove("open");
    document.getElementById("aiChatModal").setAttribute("aria-hidden", "true");
}

function findLessonById(id) {
    let lesson = null, topicTitle = "";
    COURSE_DATA.forEach(topic => topic.categories.forEach(cat => cat.lessons.forEach(item => {
        if (item.id === id) { lesson = item; topicTitle = topic.title; }
    })));
    return { lesson, topicTitle };
}

function openAiChatForLesson(lessonId) {
    const { lesson, topicTitle } = findLessonById(lessonId);
    if (!lesson) return;
    const c = lesson.content;
    const promptContext = [
        `Themenbereich: ${topicTitle}`,
        `Lektion: ${lesson.title}`,
        `Beschreibung: ${c.description}`,
        `Wichtige Punkte: ${c.keyPoints.join(" | ")}`,
        c.examTip ? `Prüfungstipp: ${c.examTip}` : ""
    ].filter(Boolean).join("\n");
    openAiChat({ type: "Lektion", title: lesson.title, body: promptContext });
}

function openAiChatForFlashcard() {
    if (!fcCards.length) { showToast("Starte zuerst ein Lernkarten-Deck.", "error"); return; }
    const card = fcCards[fcIdx];
    openAiChat({ type: "Lernkarte", title: card.q.slice(0, 80), body: `Lernkarte
Frage: ${card.q}
Erwartete Antwort: ${card.a}` });
}

async function fetchAiAnswer(settings, messages, options = {}) {
    const systemPrompt = options.systemPrompt || AI_SYSTEM_PROMPT;
    const temperature = Number.isFinite(options.temperature) ? options.temperature : 0.3;
    if (settings.provider === "gemini") {
        const endpoint = `https://generativelanguage.googleapis.com/v1beta/models/${encodeURIComponent(settings.model)}:generateContent?key=${encodeURIComponent(settings.apiKey)}`;
        const geminiParts = messages.map(m => ({ role: m.role === "assistant" ? "model" : "user", parts: [{ text: m.content }] }));
        const response = await fetch(endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ systemInstruction: { parts: [{ text: systemPrompt }] }, contents: geminiParts, generationConfig: { temperature } })
        });
        if (!response.ok) throw new Error(`Gemini API Fehler (${response.status}): ${(await response.text()).slice(0, 220)}`);
        const data = await response.json();
        return data?.candidates?.[0]?.content?.parts?.[0]?.text || "Keine Antwort erhalten.";
    }

    const response = await fetch("https://api.openai.com/v1/chat/completions", {
        method: "POST",
        headers: { "Content-Type": "application/json", Authorization: `Bearer ${settings.apiKey}` },
        body: JSON.stringify({ model: settings.model, temperature, messages: [{ role: "system", content: systemPrompt }, ...messages] })
    });
    if (!response.ok) throw new Error(`OpenAI API Fehler (${response.status}): ${(await response.text()).slice(0, 220)}`);
    const data = await response.json();
    return data?.choices?.[0]?.message?.content || "Keine Antwort erhalten.";
}

function parseJsonResponse(rawText) {
    const sanitized = rawText.trim().replace(/^```(?:json)?/i, "").replace(/```$/, "").trim();
    return JSON.parse(sanitized);
}

function resetEndlessResult(type = "") {
    const resultBox = document.getElementById("endlessResult");
    resultBox.className = `trainer-result${type ? ` ${type}` : ""}`;
    resultBox.innerHTML = "";
}

function renderEndlessTopicOptions() {
    const topicSelect = document.getElementById("endlessTopicSelect");
    if (!topicSelect) return;
    const topicOptions = COURSE_DATA.map(topic => `<option value="${escapeHtml(topic.title)}">${escapeHtml(topic.icon)} ${escapeHtml(topic.title)}</option>`).join("");
    topicSelect.innerHTML = `<option value="Gemischt">🔀 Gemischt (alle AP2-Bereiche)</option>${topicOptions}`;
}

async function generateEndlessScenario() {
    const settings = getCurrentLlmSettings();
    if (!settings.apiKey) { showToast("Bitte zuerst einen API-Key in den KI-Einstellungen hinterlegen.", "error"); return; }

    const topic = document.getElementById("endlessTopicSelect").value;
    const generateBtn = document.getElementById("endlessGenerateBtn");
    const evaluateBtn = document.getElementById("endlessEvaluateBtn");
    generateBtn.disabled = true;
    evaluateBtn.disabled = true;
    resetEndlessResult("loading");
    document.getElementById("endlessResult").textContent = "Szenario wird generiert …";

    try {
        const prompt = `Erzeuge jetzt genau ein neues Szenario für das Thema "${topic}".
Wichtig: Liefere valides JSON mit den Schlüsseln scenario, question, sample_solution.`;
        const raw = await fetchAiAnswer(settings, [{ role: "user", content: prompt }], { systemPrompt: ENDLESS_SCENARIO_SYSTEM_PROMPT, temperature: 0.7 });
        const parsed = parseJsonResponse(raw);
        if (!parsed?.scenario || !parsed?.question || !parsed?.sample_solution) throw new Error("Unvollständige JSON-Antwort.");

        endlessState = {
            topic,
            scenario: parsed.scenario.trim(),
            question: parsed.question.trim(),
            sampleSolution: parsed.sample_solution.trim()
        };

        document.getElementById("endlessMeta").textContent = `Status: Szenario aktiv • Thema: ${topic}`;
        document.getElementById("endlessScenario").textContent = endlessState.scenario;
        document.getElementById("endlessQuestion").textContent = `Leitfrage: ${endlessState.question}`;
        document.getElementById("endlessAnswerInput").value = "";
        resetEndlessResult();
        showToast("Neues Endlos-Szenario erstellt.", "success");
    } catch {
        document.getElementById("endlessMeta").textContent = "Status: Generierung fehlgeschlagen.";
        document.getElementById("endlessScenario").textContent = "Die KI konnte kein gültiges Szenario liefern. Bitte erneut versuchen.";
        document.getElementById("endlessQuestion").textContent = "Leitfrage: –";
        resetEndlessResult("incorrect");
        document.getElementById("endlessResult").textContent = "Fehler bei der Szenario-Generierung (JSON/Antwortformat prüfen).";
    } finally {
        generateBtn.disabled = false;
        evaluateBtn.disabled = false;
    }
}

async function evaluateEndlessAnswer() {
    const settings = getCurrentLlmSettings();
    if (!settings.apiKey) { showToast("Bitte zuerst einen API-Key in den KI-Einstellungen hinterlegen.", "error"); return; }
    if (!endlessState.scenario || !endlessState.question || !endlessState.sampleSolution) {
        showToast("Erzeuge zuerst ein Szenario im Endlos-Training.", "error");
        return;
    }

    const userAnswer = document.getElementById("endlessAnswerInput").value.trim();
    if (!userAnswer) {
        showToast("Bitte zuerst eine eigene Antwort eingeben.", "error");
        return;
    }

    const evaluateBtn = document.getElementById("endlessEvaluateBtn");
    evaluateBtn.disabled = true;
    resetEndlessResult("loading");
    document.getElementById("endlessResult").textContent = "Antwort wird bewertet …";

    try {
        const evalPrompt = `Szenario:
${endlessState.scenario}

Leitfrage:
${endlessState.question}

Musterlösung:
${endlessState.sampleSolution}

Nutzerantwort:
${userAnswer}

Bewerte qualitativ.`;
        const raw = await fetchAiAnswer(settings, [{ role: "user", content: evalPrompt }], { systemPrompt: ENDLESS_EVAL_SYSTEM_PROMPT, temperature: 0.2 });
        const parsed = parseJsonResponse(raw);
        const score = Number.isFinite(Number(parsed?.score)) ? Math.max(0, Math.min(100, Math.round(Number(parsed.score)))) : null;
        const strengths = Array.isArray(parsed?.strengths) ? parsed.strengths : [];
        const missing = Array.isArray(parsed?.missing) ? parsed.missing : [];
        const nextSteps = Array.isArray(parsed?.next_steps) ? parsed.next_steps : [];

        if (!parsed?.summary || !strengths.length || !missing.length) throw new Error("Unvollständige Bewertung.");

        resetEndlessResult("correct");
        document.getElementById("endlessResult").innerHTML = `
            <div class="endless-feedback">
                <strong>Qualitatives Feedback${score !== null ? ` (${score}/100)` : ""}:</strong>
                <div style="margin-top: 8px;">${escapeHtml(parsed.summary)}</div>
                <strong style="display:block; margin-top: 10px;">Was war gut:</strong>
                <ul>${strengths.map(item => `<li>${escapeHtml(String(item))}</li>`).join("")}</ul>
                <strong style="display:block; margin-top: 10px;">Was noch fehlt:</strong>
                <ul>${missing.map(item => `<li>${escapeHtml(String(item))}</li>`).join("")}</ul>
                <strong style="display:block; margin-top: 10px;">Nächste Schritte:</strong>
                <ul>${nextSteps.map(item => `<li>${escapeHtml(String(item))}</li>`).join("")}</ul>
            </div>
            <details style="margin-top: 10px; text-align: left;">
                <summary>Musterlösung anzeigen</summary>
                <div style="margin-top: 8px; line-height: 1.45;">${escapeHtml(endlessState.sampleSolution)}</div>
            </details>
        `;
    } catch {
        resetEndlessResult("incorrect");
        document.getElementById("endlessResult").textContent = "Bewertung fehlgeschlagen. Bitte erneut versuchen.";
    } finally {
        evaluateBtn.disabled = false;
    }
}

async function submitAiChat(event) {
    event.preventDefault();
    const input = document.getElementById("aiChatInput");
    const userMessage = input.value.trim();
    if (!userMessage) return;

    const settings = getCurrentLlmSettings();
    if (!settings.apiKey) { showToast("Bitte zuerst einen API-Key in den KI-Einstellungen hinterlegen.", "error"); return; }

    const contextPrompt = `Aktueller Lernkontext:
${aiChatState.contextBody}`;
    const conversation = [{ role: "system", content: contextPrompt }, ...aiChatState.messages.filter(m => m.role !== "system")];

    aiChatState.messages.push({ role: "user", content: userMessage });
    renderAiChatMessages();
    input.value = "";
    setAiChatStatus("Antwort wird generiert …");
    document.getElementById("aiChatSendBtn").disabled = true;

    try {
        const answer = await fetchAiAnswer(settings, [...conversation, { role: "user", content: userMessage }]);
        aiChatState.messages.push({ role: "assistant", content: answer.trim() });
        renderAiChatMessages();
        setAiChatStatus(`Antwort von ${settings.provider.toUpperCase()} (${settings.model})`);
    } catch (error) {
        setAiChatStatus("Fehler bei der API-Anfrage");
        showToast("KI-Antwort fehlgeschlagen. Prüfe Key, Modell und Provider.", "error");
    } finally {
        document.getElementById("aiChatSendBtn").disabled = false;
    }
}

