function startFC(topicId) {
    fcCards = []; fcIdx = 0;
    const nowTs = nowDate().getTime();
    COURSE_DATA.forEach(t => {
        if(topicId === 'all' || t.id === topicId) {
            t.categories.forEach(c => c.lessons.forEach(l => {
                if (l.content.flashcards) {
                    l.content.flashcards.forEach(card => {
                        const id = getCardId(card);
                        const schedule = getCardSchedule(id);
                        fcCards.push({ ...card, id, schedule });
                    });
                }
            }));
        }
    });
    let dueCards = [];
    const futureCards = [];
    fcCards.forEach(card => {
        const dueTs = getDueTime(card.schedule);
        if (dueTs <= nowTs) dueCards.push(card);
        else futureCards.push(card);
    });
    dueCards.sort((a, b) => getDueTime(a.schedule) - getDueTime(b.schedule));
    dueCards = shuffleArray(dueCards);
    futureCards.sort((a, b) => getDueTime(a.schedule) - getDueTime(b.schedule));
    fcCards = [...dueCards, ...futureCards];

    document.getElementById("fc-setup-view").style.display = "none";
    document.getElementById("fc-active-view").style.display = "flex";
    updateFC();
}

function stopFlashcards() {
    document.getElementById("fc-setup-view").style.display = "block";
    document.getElementById("fc-active-view").style.display = "none";
}

function flipCard() {
    document.getElementById("fc-card").classList.toggle("is-flipped");
    const isFlipped = document.getElementById("fc-card").classList.contains("is-flipped");
    setRatingButtonsEnabled(isFlipped);
}

function goToNextCard() {
    document.getElementById("fc-card").classList.remove("is-flipped");
    setRatingButtonsEnabled(false);
    setTimeout(() => {
        fcIdx++;
        if(fcIdx >= fcCards.length) {
            showToast("Deck abgeschlossen! Neue Reihenfolge nach Fälligkeit erstellt.", "success");
            fcIdx = 0;
            fcCards.sort((a, b) => getDueTime(getCardSchedule(a.id)) - getDueTime(getCardSchedule(b.id)));
        }
        updateFC();
    }, 200);
}

function rateCurrentCard(rating) {
    const current = fcCards[fcIdx];
    if (!current) return;
    const existing = getCardSchedule(current.id);
    const now = nowDate();
    let { interval, ease, repetitions } = existing;
    ease = Math.max(1.3, ease || 2.5);
    repetitions = repetitions || 0;
    interval = interval || 0;

    if (rating === "repeat") {
        repetitions = 0;
        interval = 1;
        ease = Math.max(1.3, ease - 0.2);
    } else if (rating === "good") {
        repetitions += 1;
        if (repetitions === 1) interval = 1;
        else if (repetitions === 2) interval = 3;
        else interval = Math.max(1, Math.round(interval * ease));
    } else if (rating === "easy") {
        repetitions += 1;
        if (repetitions === 1) interval = 3;
        else interval = Math.max(2, Math.round(interval * (ease + 0.3)));
        ease = Math.min(3.2, ease + 0.15);
    }

    const dueDate = addDays(now, interval);
    Storage.data.flashcards[current.id] = {
        interval,
        ease,
        due: dueDate.toISOString(),
        repetitions
    };
    Storage.save();
    goToNextCard();
}

function updateFC() {
    if (!fcCards.length) {
        document.getElementById("fc-question").textContent = "Keine Lernkarten verfügbar.";
        document.getElementById("fc-answer").textContent = "Bitte anderes Thema auswählen.";
        setRatingButtonsEnabled(false);
        return;
    }
    document.getElementById("fc-question").innerHTML = fcCards[fcIdx].q;
    document.getElementById("fc-answer").innerHTML = fcCards[fcIdx].a;
    setRatingButtonsEnabled(false);
}


