        if(count > 0) {
            grid.innerHTML += `<button class="fc-topic-btn" type="button" onclick="startFC('${t.id}')"><div style="font-size:2rem">${t.icon}</div><div style="font-weight:bold; margin-top:10px;">${t.title}</div><div style="font-size:0.8rem; color:var(--text-tertiary)">${count} Karten</div></button>`;
        }
