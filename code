function startFC(topicId) {
    fcCards = []; fcIdx = 0;
    COURSE_DATA.forEach(t => {
        if(topicId === 'all' || t.id === topicId) {
            t.categories.forEach(c => c.lessons.forEach(l => {
                if(l.content.flashcards) fcCards.push(...l.content.flashcards);
            }));
        }
    });
    fcCards.sort(() => Math.random() - 0.5); // Shuffle
    document.getElementById("fc-setup-view").style.display = "none";
    document.getElementById("fc-active-view").style.display = "flex";
    updateFC();
}

function stopFlashcards() {
    document.getElementById("fc-setup-view").style.display = "block";
    document.getElementById("fc-active-view").style.display = "none";
}

function flipCard() { document.getElementById("fc-card").classList.toggle("is-flipped"); }

function nextCard() {
    document.getElementById("fc-card").classList.remove("is-flipped");
    setTimeout(() => {
        fcIdx++;
        if(fcIdx >= fcCards.length) { showToast("Deck abgeschlossen!", "success"); fcIdx=0; fcCards.sort(() => Math.random() - 0.5); }
        updateFC();
    }, 200);
}

function updateFC() {
    document.getElementById("fc-question").innerHTML = fcCards[fcIdx].q;
    document.getElementById("fc-answer").innerHTML = fcCards[fcIdx].a;
}

/* ========================================
   INTERAKTIVER TRAINER (Rechner)
   ======================================== */

// Subnetting State
let curSub = { ip: "", cidr: 0, net: "", bcast: "", hosts: 0 };

function intToIp(int) {
    return [ (int >>> 24) & 255, (int >>> 16) & 255, (int >>> 8) & 255, int & 255 ].join('.');
}
function ipToInt(ip) {
    return ip.split('.').reduce((acc, octet) => (acc << 8) + parseInt(octet, 10), 0) >>> 0;
}

function generateSubnetTask() {
    // Generate valid Class C for easy but realistic training (/24 to /29)
    const baseIp = `192.168.${Math.floor(Math.random()*255)}.${Math.floor(Math.random()*256)}`;
    const cidr = Math.floor(Math.random() * (29 - 24 + 1)) + 24;
    
    curSub.ip = baseIp;
    curSub.cidr = cidr;
    
    const ipInt = ipToInt(baseIp);
    const hostBits = 32 - cidr;
    const maskInt = (0xFFFFFFFF << hostBits) >>> 0;
    
    const netInt = (ipInt & maskInt) >>> 0;
    const bcastInt = (netInt | ~maskInt) >>> 0;
    
    curSub.net = intToIp(netInt);
    curSub.bcast = intToIp(bcastInt);
    curSub.hosts = Math.pow(2, hostBits) - 2;

    document.getElementById("subnetTaskText").textContent = `IP: ${curSub.ip} /${curSub.cidr}`;
    document.getElementById("subnetInNetwork").value = "";
    document.getElementById("subnetInBroadcast").value = "";
    document.getElementById("subnetInHosts").value = "";
    document.getElementById("subnetResult").className = "trainer-result";
}

function checkSubnet() {
    const net = document.getElementById("subnetInNetwork").value.trim();
    const bcast = document.getElementById("subnetInBroadcast").value.trim();
    const hosts = parseInt(document.getElementById("subnetInHosts").value.trim());

    const resBox = document.getElementById("subnetResult");
    if (net === curSub.net && bcast === curSub.bcast && hosts === curSub.hosts) {
        resBox.textContent = "Korrekt! Perfekt gelöst.";
        resBox.className = "trainer-result correct";
    } else {
        const hostBits = 32 - curSub.cidr;
        const totalAddresses = Math.pow(2, hostBits);
        const maskInt = (0xFFFFFFFF << hostBits) >>> 0;
        const subnetMask = intToIp(maskInt);
        resBox.innerHTML = `
            Fehler.<br>
            Richtig wäre:<br>
            Netz-ID: ${curSub.net}<br>
            Broadcast: ${curSub.bcast}<br>
            Hosts: ${curSub.hosts}<br><br>
            <strong>Rechenweg:</strong><br>
            /${curSub.cidr} bedeutet ${hostBits} Host-Bits → 2^${hostBits} = ${totalAddresses} Adressen.<br>
            Nutzbare Hosts: ${totalAddresses} - 2 (Netz-ID & Broadcast) = ${curSub.hosts}.<br>
            Subnetzmaske: ${subnetMask}.<br>
            Netz-ID = IP AND Maske, Broadcast = Netz-ID + Host-Bits auf 1.
        `;
        resBox.className = "trainer-result incorrect";
    }
}

// RAID State
let curRaid = { level: 0, disks: 0, size: 0, cap: 0 };

function generateRaidTask() {
    const levels = [1, 5, 6, 10];
    const sizes = [1, 2, 4, 8, 10];
    
    curRaid.level = levels[Math.floor(Math.random() * levels.length)];
    curRaid.size = sizes[Math.floor(Math.random() * sizes.length)];
    
    if (curRaid.level === 1) curRaid.disks = 2;
    else if (curRaid.level === 5) curRaid.disks = Math.floor(Math.random() * 4) + 3; // 3 to 6
    else if (curRaid.level === 6) curRaid.disks = Math.floor(Math.random() * 3) + 4; // 4 to 6
    else if (curRaid.level === 10) curRaid.disks = [4, 6, 8][Math.floor(Math.random() * 3)];

    // Calculate Capacity
    if (curRaid.level === 1) curRaid.cap = curRaid.size;
    else if (curRaid.level === 5) curRaid.cap = (curRaid.disks - 1) * curRaid.size;
    else if (curRaid.level === 6) curRaid.cap = (curRaid.disks - 2) * curRaid.size;
    else if (curRaid.level === 10) curRaid.cap = (curRaid.disks / 2) * curRaid.size;

    document.getElementById("raidTaskText").textContent = `Ein Server benötigt ein RAID ${curRaid.level}. Verbaut werden ${curRaid.disks} Festplatten, jede mit einer Kapazität von ${curRaid.size} TB.`;
    document.getElementById("raidInCap").value = "";
    document.getElementById("raidResult").className = "trainer-result";
}

function checkRaid() {
    const input = parseFloat(document.getElementById("raidInCap").value.trim());
    const resBox = document.getElementById("raidResult");
    
    if (input === curRaid.cap) {
        resBox.textContent = "Korrekt! Richtig gerechnet.";
        resBox.className = "trainer-result correct";
    } else {
        let formula = "";
        let calc = "";

        if (curRaid.level === 1) {
            formula = "RAID 1: Netto = 1 × Plattengröße (Spiegelung).";
            calc = `1 × ${curRaid.size} TB = ${curRaid.cap} TB`;
        } else if (curRaid.level === 5) {
            formula = "RAID 5: Netto = (Anzahl Platten - 1) × Plattengröße.";
            calc = `(${curRaid.disks} - 1) × ${curRaid.size} TB = ${curRaid.cap} TB`;
        } else if (curRaid.level === 6) {
            formula = "RAID 6: Netto = (Anzahl Platten - 2) × Plattengröße.";
            calc = `(${curRaid.disks} - 2) × ${curRaid.size} TB = ${curRaid.cap} TB`;
        } else if (curRaid.level === 10) {
            formula = "RAID 10: Netto = (Anzahl Platten / 2) × Plattengröße.";
            calc = `(${curRaid.disks} / 2) × ${curRaid.size} TB = ${curRaid.cap} TB`;
        }

        resBox.innerHTML = `
            Leider falsch. Die Netto-Kapazität beträgt ${curRaid.cap} TB.<br><br>
            <strong>Rechenweg:</strong><br>
            ${formula}<br>
            ${calc}
        `;
        resBox.className = "trainer-result incorrect";
    }
}

