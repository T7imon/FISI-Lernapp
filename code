let fcCards = [];
let fcIdx = 0;

function nowDate() {
    return new Date();
}

function addDays(date, days) {
    const d = new Date(date);
    d.setUTCDate(d.getUTCDate() + days);
    return d;
}

function shuffleArray(items) {
    const arr = [...items];
    for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
}

function getCardId(card) {
    const base = `${card.q}|||${card.a}`;
    let hash = 0;
    for (let i = 0; i < base.length; i++) {
        hash = ((hash << 5) - hash + base.charCodeAt(i)) | 0;
    }
    return `fc_${Math.abs(hash)}`;
}

function getCardSchedule(cardId) {
    return Storage.data.flashcards[cardId] || { interval: 0, ease: 2.5, due: null, repetitions: 0 };
}

function getDueTime(schedule) {
    if (!schedule?.due) return 0;
    const parsed = Date.parse(schedule.due);
    return Number.isNaN(parsed) ? 0 : parsed;
}

function setRatingButtonsEnabled(isEnabled) {
    ["fc-rate-repeat", "fc-rate-good", "fc-rate-easy"].forEach(id => {
        const btn = document.getElementById(id);
        if (btn) btn.disabled = !isEnabled;
    });
}

function renderFlashcardSetup() {
    const grid = document.getElementById("fc-topic-grid");
    grid.innerHTML = `<button class="fc-topic-btn" type="button" onclick="startFC('all')"><div style="font-size:2rem">📚</div><div style="font-weight:bold; margin-top:10px;">Alle Themen mixen</div></button>`;
    COURSE_DATA.forEach(t => {
        let count = 0;
        t.categories.forEach(c => c.lessons.forEach(l => { if(l.content.flashcards) count += l.content.flashcards.length; }));
        if(count > 0) {
            grid.innerHTML += `<button class="fc-topic-btn" type="button" onclick="startFC('${t.id}')"><div style="font-size:2rem">${t.icon}</div><div style="font-weight:bold; margin-top:10px;">${t.title}</div><div style="font-size:0.8rem; color:var(--text-tertiary)">${count} Karten</div></button>`;
        }
    });
