<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FISI Prüfungstrainer – AP Teil 2</title>
<style>
/* ========================================
   FISI Prüfungstrainer – Stylesheet
   ======================================== */

:root {
  --bg-primary: #f5f5f0;
  --bg-secondary: #ffffff;
  --bg-tertiary: #eeeee8;
  --bg-sidebar: #1a1a2e;
  --bg-sidebar-hover: #252542;
  --text-primary: #1a1a1a;
  --text-secondary: #5a5a5a;
  --text-tertiary: #8a8a8a;
  --text-sidebar: #c8c8d4;
  --text-sidebar-active: #ffffff;
  --accent: #3d5af1;
  --accent-light: #eef0ff;
  --accent-glow: rgba(61, 90, 241, 0.15);
  --success: #22c55e;
  --success-light: #edfcf2;
  --warning: #f59e0b;
  --warning-light: #fef9ec;
  --danger: #ef4444;
  --danger-light: #fef2f2;
  --border: #e2e2da;
  --border-light: #ececec;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.06);
  --shadow-lg: 0 8px 30px rgba(0,0,0,0.08);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --font-body: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --sidebar-w: 260px;
  --topbar-h: 64px;
  --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

[data-theme="dark"] {
  --bg-primary: #0f0f17;
  --bg-secondary: #1a1a28;
  --bg-tertiary: #24243a;
  --bg-sidebar: #0a0a14;
  --bg-sidebar-hover: #16162a;
  --text-primary: #ededf0;
  --text-secondary: #9999aa;
  --text-tertiary: #666677;
  --text-sidebar: #8888aa;
  --text-sidebar-active: #ffffff;
  --accent: #6c8aff;
  --accent-light: #1a1a3a;
  --accent-glow: rgba(108, 138, 255, 0.12);
  --success: #34d672;
  --success-light: #0d2618;
  --warning: #f5a623;
  --warning-light: #2a2010;
  --danger: #f87171;
  --danger-light: #2a1010;
  --border: #2a2a40;
  --border-light: #222238;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body { font-family: var(--font-body); background: var(--bg-primary); color: var(--text-primary); line-height: 1.6; display: flex; min-height: 100vh; overflow-x: hidden; transition: background var(--transition), color var(--transition); }

/* — Sidebar — */
.sidebar { width: var(--sidebar-w); background: var(--bg-sidebar); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
.sidebar-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 20px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); }
.logo { display: flex; align-items: center; gap: 10px; }
.logo-icon { width: 36px; height: 36px; background: var(--accent); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.2rem;}
.logo-text { font-weight: 700; font-size: 1.05rem; color: #fff; }
.sidebar-close { display: none; background: none; border: none; color: var(--text-sidebar); cursor: pointer; padding: 4px; font-size: 1.2rem;}
.sidebar-nav { flex: 1; padding: 12px 10px; display: flex; flex-direction: column; gap: 4px; overflow-y: auto;}
.nav-item { display: flex; align-items: center; gap: 12px; padding: 11px 14px; border-radius: var(--radius-sm); color: var(--text-sidebar); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: all var(--transition); }
.nav-item:hover { background: var(--bg-sidebar-hover); color: var(--text-sidebar-active); }
.nav-item.active { background: var(--accent); color: #fff; }
.sidebar-footer { padding: 16px 20px 20px; border-top: 1px solid rgba(255,255,255,0.06); }
.mini-progress-label { font-size: 0.72rem; text-transform: uppercase; color: var(--text-sidebar); margin-bottom: 8px; font-weight: 600; }
.mini-progress-bar { height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; }
.mini-progress-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.6s; width: 0%; }

/* — Main Content & Topbar — */
.main-content { flex: 1; margin-left: var(--sidebar-w); min-height: 100vh; transition: margin var(--transition); display: flex; flex-direction: column;}
.topbar { height: var(--topbar-h); display: flex; align-items: center; gap: 16px; padding: 0 28px; background: var(--bg-secondary); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50; }
.hamburger { display: none; background: none; border: none; color: var(--text-primary); cursor: pointer; padding: 6px; font-size: 1.2rem;}
.topbar-search { flex: 1; max-width: 400px; display: flex; align-items: center; gap: 8px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 8px 14px; }
.topbar-search input { border: none; background: none; outline: none; font-family: var(--font-body); font-size: 0.88rem; color: var(--text-primary); width: 100%; }
.topbar-actions { display: flex; gap: 8px; margin-left: auto; }
.theme-toggle { width: 38px; height: 38px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-primary); color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.1rem;}

/* — Pages & General Layout — */
.page-container { padding: 28px; max-width: 1100px; margin: 0 auto; width: 100%; flex: 1;}
.page { display: none; animation: fadeIn 0.3s ease; }
.page.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.page-header { margin-bottom: 28px; }
.page-header h1 { font-size: 1.75rem; font-weight: 700; line-height: 1.2; }
.page-subtitle { color: var(--text-secondary); margin-top: 6px; font-size: 0.95rem; }
.section-title { font-size: 1.1rem; font-weight: 600; margin: 32px 0 16px; }

/* Buttons */
.btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 20px; border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 0.88rem; font-weight: 600; border: none; cursor: pointer; transition: all var(--transition); }
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
.btn-success { background: var(--success); color: #fff; }
.btn-secondary { background: var(--bg-primary); color: var(--text-secondary); border: 1px solid var(--border); }
.btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
.btn-danger { background: var(--danger); color: #fff; }

/* Inputs */
.input-field { width: 100%; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 0.9rem; background: var(--bg-primary); color: var(--text-primary); transition: all 0.2s; }
.input-field:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }

/* — Dashboard components — */
.hero-progress-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px; display: flex; align-items: center; gap: 40px; box-shadow: var(--shadow-md); }
.hero-progress-ring-wrap { position: relative; width: 120px; height: 120px; flex-shrink: 0; }
.hero-ring { width: 100%; height: 100%; transform: rotate(-90deg); }
.ring-bg { fill: none; stroke: var(--bg-tertiary); stroke-width: 8; }
.ring-fill { fill: none; stroke: var(--accent); stroke-width: 8; stroke-linecap: round; stroke-dasharray: 326.73; stroke-dashoffset: 326.73; transition: stroke-dashoffset 1s; }
.hero-ring-text { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.hero-ring-value { font-size: 1.6rem; font-weight: 700; font-family: var(--font-mono); }
.hero-stats { display: flex; gap: 32px; flex: 1; }
.hero-stat-value { font-size: 1.8rem; font-weight: 700; font-family: var(--font-mono); }
.hero-stat-label { font-size: 0.78rem; color: var(--text-tertiary); font-weight: 500; }
.topic-progress-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
.topic-progress-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 20px; cursor: pointer; transition: all var(--transition); border-bottom: 3px solid transparent;}
.topic-progress-card:hover { border-color: var(--accent); box-shadow: var(--shadow-md); transform: translateY(-2px); }
.tpc-icon { width: 40px; height: 40px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; margin-bottom: 12px; }
.tpc-title { font-weight: 600; font-size: 0.95rem; margin-bottom: 4px; }
.tpc-bar { height: 6px; background: var(--bg-tertiary); border-radius: 3px; overflow: hidden; margin-top: 12px;}
.tpc-bar-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.6s; }

/* — Topics & Lessons List — */
.filter-chips { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px;}
.chip { padding: 7px 16px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-secondary); font-size: 0.82rem; cursor: pointer; transition: all var(--transition); }
.chip.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.topic-group { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; margin-bottom: 12px; }
.topic-group-header { display: flex; align-items: center; gap: 14px; padding: 18px 20px; cursor: pointer; }
.topic-group-icon { width: 38px; height: 38px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
.topic-group-info { flex: 1; }
.topic-group-title { font-weight: 600; font-size: 0.95rem; }
.topic-group-progress { width: 60px; height: 6px; background: var(--bg-tertiary); border-radius: 3px; }
.topic-group-progress-fill { height: 100%; background: var(--accent); }
.topic-group-body { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
.topic-group.open .topic-group-body { max-height: 2000px; }
.subtopic-group { border-top: 1px solid var(--border-light); }
.subtopic-header { display: flex; padding: 12px 20px 12px 36px; cursor: pointer; font-weight: 600; font-size: 0.88rem; color: var(--text-secondary); }
.subtopic-body { max-height: 0; overflow: hidden; }
.subtopic-group.open .subtopic-body { max-height: 2000px; }
.lesson-item { display: flex; align-items: center; gap: 12px; padding: 12px 20px 12px 54px; cursor: pointer; border-top: 1px solid var(--border-light); }
.lesson-item:hover { background: var(--bg-tertiary); }
.lesson-checkbox { width: 22px; height: 22px; border-radius: 6px; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 0.8rem;}
.lesson-checkbox.checked { background: var(--success); border-color: var(--success); color: white;}
.lesson-item-info { flex: 1; font-size: 0.88rem; font-weight: 500;}

/* — Lesson View Detailed — */
.lesson-container { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); }
.lesson-header { padding: 28px; border-bottom: 1px solid var(--border); }
.lesson-breadcrumb { font-size: 0.75rem; color: var(--text-tertiary); margin-bottom: 8px; font-weight: 600;}
.lesson-title { font-size: 1.4rem; font-weight: 700; }
.lesson-body { padding: 28px; }
.lesson-section { margin-bottom: 24px; }
.lesson-section h3 { font-size: 1rem; color: var(--accent); margin-bottom: 10px; }
.lesson-section p, .lesson-section li { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.7;}
.lesson-section ul { list-style: none; }
.lesson-section ul li { padding: 6px 0 6px 20px; position: relative; }
.lesson-section ul li::before { content: '▸'; position: absolute; left: 0; color: var(--accent); }
.key-terms { background: var(--accent-light); border-left: 3px solid var(--accent); padding: 16px; margin: 16px 0; border-radius: var(--radius-sm); }
.exam-tip { background: var(--warning-light); border-left: 3px solid var(--warning); padding: 16px; margin: 16px 0; border-radius: var(--radius-sm); }
.lesson-footer { padding: 20px 28px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; }

/* — Flashcards — */
.fc-setup { background: var(--bg-secondary); padding: 24px; border-radius: var(--radius-lg); border: 1px solid var(--border); margin-bottom: 20px; }
.fc-topic-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; margin-top: 16px; }
.fc-topic-btn { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 20px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: var(--radius-md); cursor: pointer; transition: all var(--transition); text-align: center;}
.fc-topic-btn:hover { border-color: var(--accent); box-shadow: var(--shadow-sm); transform: translateY(-2px); }
.fc-active-session { display: flex; flex-direction: column; align-items: center; margin-top: 20px; }
.fc-scene { perspective: 1000px; width: 100%; max-width: 600px; height: 350px; margin-bottom: 24px; }
.fc-card { width: 100%; height: 100%; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); transform-style: preserve-3d; cursor: pointer; position: relative; border-radius: var(--radius-lg); box-shadow: var(--shadow-md); }
.fc-card.is-flipped { transform: rotateY(180deg); }
.fc-face { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; border-radius: var(--radius-lg); border: 2px solid var(--border); text-align: center; overflow-y: auto; }
.fc-front { background: var(--bg-secondary); color: var(--text-primary); }
.fc-back { background: var(--accent-light); border-color: var(--accent); color: var(--text-primary); transform: rotateY(180deg); }
.fc-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary); margin-bottom: 16px; font-weight: 700; }
.fc-text { font-size: 1.1rem; font-weight: 500; line-height: 1.5; }

/* — INTERAKTIVER TRAINER (Rechner) — */
.trainer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px; }
.trainer-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; box-shadow: var(--shadow-sm); }
.trainer-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.trainer-icon { width: 40px; height: 40px; border-radius: var(--radius-sm); background: var(--accent-light); color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
.trainer-title { font-size: 1.1rem; font-weight: 700; }
.trainer-task-box { background: var(--bg-primary); border-left: 4px solid var(--accent); padding: 16px; border-radius: 4px; margin-bottom: 20px; font-family: var(--font-mono); font-size: 0.95rem; }
.trainer-form { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px;}
.trainer-form-group { display: flex; flex-direction: column; gap: 6px; }
.trainer-form-group label { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); }
.trainer-result { padding: 12px; border-radius: var(--radius-sm); font-weight: 600; font-size: 0.9rem; text-align: center; display: none; margin-top: 12px;}
.trainer-result.correct { background: var(--success-light); color: var(--success); display: block; border: 1px solid var(--success); }
.trainer-result.incorrect { background: var(--danger-light); color: var(--danger); display: block; border: 1px solid var(--danger); }

/* Toasts */
.toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
.toast { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 12px 20px; font-size: 0.85rem; font-weight: 500; box-shadow: var(--shadow-lg); border-left: 3px solid var(--accent); animation: toastIn 0.3s ease;}
.toast.success { border-left-color: var(--success); }
.toast.error { border-left-color: var(--danger); }

@media (max-width: 768px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  .sidebar-close, .hamburger { display: block; }
  .main-content { margin-left: 0; }
  .hero-progress-card { flex-direction: column; padding: 24px; text-align: center; }
  .fc-scene { height: 300px; }
}
</style>
