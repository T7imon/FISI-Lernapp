const Storage = {
  _data: null,
  _defaults() { return { completed: [], theme: "light", llm: { provider: "openai", apiKey: "", model: "gpt-4.1-mini" }, flashcards: {} }; },
  _normalize(data) {
    const defaults = this._defaults();
    const rawCompleted = Array.isArray(data?.completed) ? data.completed : defaults.completed;
    const validLessonIds = new Set();
    COURSE_DATA.forEach(topic => topic.categories.forEach(cat => cat.lessons.forEach(lesson => validLessonIds.add(lesson.id))));

    const completed = [...new Set(rawCompleted.filter(id => typeof id === "string" && validLessonIds.has(id)))];
    const theme = data?.theme === "dark" ? "dark" : "light";
    const provider = data?.llm?.provider === "gemini" ? "gemini" : "openai";
    const apiKey = typeof data?.llm?.apiKey === "string" ? data.llm.apiKey : "";
    const modelDefault = provider === "gemini" ? "gemini-2.0-flash" : "gpt-4.1-mini";
    const model = typeof data?.llm?.model === "string" && data.llm.model.trim() ? data.llm.model.trim() : modelDefault;
    const flashcards = {};
    if (data?.flashcards && typeof data.flashcards === "object") {
      for (const [cardId, meta] of Object.entries(data.flashcards)) {
        if (typeof cardId !== "string" || !meta || typeof meta !== "object") continue;
        const interval = Number(meta.interval);
        const ease = Number(meta.ease);
        const due = typeof meta.due === "string" ? meta.due : null;
        const repetitions = Number(meta.repetitions);
        flashcards[cardId] = {
          interval: Number.isFinite(interval) && interval >= 0 ? interval : 0,
          ease: Number.isFinite(ease) && ease >= 1.3 ? ease : 2.5,
          due: due && !Number.isNaN(Date.parse(due)) ? due : null,
          repetitions: Number.isFinite(repetitions) && repetitions >= 0 ? repetitions : 0
        };
      }
    }
    return { completed, theme, llm: { provider, apiKey, model }, flashcards };
  },
  load() {
    try {
      const r = localStorage.getItem("ap2-master");
      this._data = r ? this._normalize({...this._defaults(), ...JSON.parse(r)}) : this._defaults();
    } catch {
      this._data = this._defaults();
    }
  },
  save() { localStorage.setItem("ap2-master", JSON.stringify(this._data)); },
  get data() { if (!this._data) this.load(); return this._data; },
  replace(data) {
    this._data = this._normalize(data);
    this.save();
    return this._data;
  },
  toggleLesson(id) {
    if(this.data.completed.includes(id)) {
      this.data.completed = this.data.completed.filter(x => x !== id);
    } else {
      this.data.completed.push(id);
    }
    this.save();
  },
  isCompleted(id) { return this.data.completed.includes(id); }
};

