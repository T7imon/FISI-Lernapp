<body>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon">🔥</div>
                <span class="logo-text">AP2 Master</span>
            </div>
            <button class="sidebar-close" id="sidebarClose">✕</button>
        </div>
        <nav class="sidebar-nav">
            <a href="#" class="nav-item active" data-page="dashboard">📊 Dashboard</a>
            <a href="#" class="nav-item" data-page="topics">📚 Alle Themen</a>
            <a href="#" class="nav-item" data-page="flashcards">🗂️ Lernkarten</a>
            <a href="#" class="nav-item" data-page="trainer" style="background: var(--accent-glow); border-left: 3px solid var(--accent);">🧮 Rechen-Trainer</a>
            <a href="#" class="nav-item" data-page="stats">📈 Statistiken</a>
        </nav>
        <div class="sidebar-footer">
            <div class="mini-progress-label">Gesamtfortschritt</div>
            <div class="mini-progress-bar"><div class="mini-progress-fill" id="sidebarProgress"></div></div>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <button class="hamburger" id="hamburger">☰</button>
            <div class="topbar-search">
                <input type="text" id="searchInput" placeholder="Themen durchsuchen…">
            </div>
            <div class="topbar-actions">
                <button class="theme-toggle" id="themeToggle">🌓</button>
            </div>
        </header>

        <div class="page-container">
            <section class="page active" id="page-dashboard">
                <div class="page-header">
                    <h1>Dein Weg zur Eins 🏆</h1>
                    <p class="page-subtitle">Bereite dich systematisch auf die IHK-Abschlussprüfung vor.</p>
                </div>
                <div class="hero-progress-card">
                    <div class="hero-progress-ring-wrap">
                        <svg class="hero-ring" viewBox="0 0 120 120">
                            <circle cx="60" cy="60" r="52" class="ring-bg"/>
                            <circle cx="60" cy="60" r="52" class="ring-fill" id="heroRingFill"/>
                        </svg>
                        <div class="hero-ring-text">
                            <span class="hero-ring-value" id="heroPercent">0%</span>
                        </div>
                    </div>
                    <div class="hero-stats">
                        <div class="hero-stat"><span class="hero-stat-value" id="statCompleted">0</span><span class="hero-stat-label">Erledigt</span></div>
                        <div class="hero-stat"><span class="hero-stat-value" id="statTotal">0</span><span class="hero-stat-label">Gesamt</span></div>
                    </div>
                </div>
                <h2 class="section-title">Dein Lernfortschritt</h2>
                <div class="topic-progress-grid" id="topicProgressGrid"></div>
            </section>

            <section class="page" id="page-topics">
                <div class="page-header">
                    <h1>Prüfungsthemen</h1>
                    <p class="page-subtitle">Alle IHK-relevanten Themenfelder strukturiert aufbereitet.</p>
                </div>
                <div class="filter-chips">
                    <button class="chip active" data-filter="all">Alle</button>
                    <button class="chip" data-filter="open">Offen</button>
                    <button class="chip" data-filter="done">Erledigt</button>
                </div>
                <div class="topics-list" id="topicsList"></div>
            </section>

            <section class="page" id="page-flashcards">
                <div class="page-header">
                    <h1>Lernkarten 🗂️</h1>
                    <p class="page-subtitle">Aktiver Wissensabruf für das Langzeitgedächtnis.</p>
                </div>
                <div id="fc-setup-view" class="fc-setup">
                    <h3>Thema auswählen:</h3>
                    <div class="fc-topic-grid" id="fc-topic-grid"></div>
                </div>
                <div id="fc-active-view" class="fc-active-session" style="display:none;">
                    <button class="btn btn-secondary" style="align-self: flex-start; margin-bottom: 20px;" onclick="stopFlashcards()">← Zurück</button>
                    <div class="fc-scene">
                        <button class="fc-card" id="fc-card" type="button" aria-label="Lernkarte umdrehen" onclick="flipCard()">
                            <div class="fc-face fc-front">
                                <span class="fc-label">Frage</span>
                                <div class="fc-text" id="fc-question">...</div>
                            </div>
                            <div class="fc-face fc-back">
                                <span class="fc-label">Antwort</span>
                                <div class="fc-text" id="fc-answer">...</div>
                            </div>
