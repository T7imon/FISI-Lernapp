function renderTopics(filter="all", rawSearchTerm = "") {
    const list = document.getElementById("topicsList");
    list.innerHTML = "";
    const searchTerm = rawSearchTerm.trim().toLowerCase();

    COURSE_DATA.forEach(topic => {
        const topicMatches = topic.title.toLowerCase().includes(searchTerm);
        let html = `<div class="topic-group open">
            <div class="topic-group-header" role="button" tabindex="0">
                <div class="topic-group-icon" style="background:${topic.color}20; color:${topic.color}">${topic.icon}</div>
                <div class="topic-group-title">${topic.title}</div>
            </div><div class="topic-group-body">`;
        
        let hasContent = false;
        topic.categories.forEach(cat => {
            const catMatches = cat.title.toLowerCase().includes(searchTerm);
            let catHtml = `<div class="subtopic-group open"><div class="subtopic-header" role="button" tabindex="0">${cat.title}</div><div class="subtopic-body">`;
            let hasLesson = false;
            cat.lessons.forEach(l => {
                const done = Storage.isCompleted(l.id);
                if(filter === "done" && !done) return;
                if(filter === "open" && done) return;

                const lessonMatches = l.title.toLowerCase().includes(searchTerm);
                const includeBySearch = !searchTerm || topicMatches || catMatches || lessonMatches;
                if(!includeBySearch) return;

                hasLesson = true; hasContent = true;
                catHtml += `
                    <div class="lesson-item" role="button" tabindex="0" onclick="openLesson('${l.id}')" onkeydown="activateOnKey(event, () => openLesson('${l.id}'))">
                        <button class="lesson-checkbox ${done ? 'checked':''}" type="button" onclick="event.stopPropagation(); toggleLesson('${l.id}')" aria-label="Lektion ${done ? "als offen markieren" : "als erledigt markieren"}">✓</button>
                        <div class="lesson-item-info">${l.title}</div>
                    </div>`;
            });
            catHtml += `</div></div>`;
            if(hasLesson) html += catHtml;
        });
        html += `</div></div>`;
        if(hasContent) list.innerHTML += html;
    });

    if (!list.innerHTML) {
        list.innerHTML = `<div class="topic-group"><div class="topic-group-header"><div class="topic-group-title">Keine Treffer gefunden.</div></div></div>`;
    }
}

