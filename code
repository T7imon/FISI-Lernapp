const Storage = {
  _data: null,
  _defaults() { return { completed: [], theme: "light" }; },
  _normalize(data) {
    const defaults = this._defaults();
    const rawCompleted = Array.isArray(data?.completed) ? data.completed : defaults.completed;
    const validLessonIds = new Set();
    COURSE_DATA.forEach(topic => topic.categories.forEach(cat => cat.lessons.forEach(lesson => validLessonIds.add(lesson.id))));

    const completed = [...new Set(rawCompleted.filter(id => typeof id === "string" && validLessonIds.has(id)))];
    const theme = data?.theme === "dark" ? "dark" : "light";
    return { completed, theme };
  },
  load() {
    try {
      const r = localStorage.getItem("ap2-master");
      this._data = r ? this._normalize({...this._defaults(), ...JSON.parse(r)}) : this._defaults();
    } catch {
      this._data = this._defaults();
    }
  },
  save() { localStorage.setItem("ap2-master", JSON.stringify(this._data)); },
  get data() { if (!this._data) this.load(); return this._data; },
  replace(data) {
    this._data = this._normalize(data);
    this.save();
    return this._data;
  },
  toggleLesson(id) {
    if(this.data.completed.includes(id)) {
      this.data.completed = this.data.completed.filter(x => x !== id);
    } else {
      this.data.completed.push(id);
    }
    this.save();
  },
  isCompleted(id) { return this.data.completed.includes(id); }
};

function navigateTo(pageId) {
    document.querySelectorAll(".page").forEach(p => p.classList.remove("active"));
    document.getElementById(`page-${pageId}`).classList.add("active");
    
    document.querySelectorAll(".nav-item").forEach(n => n.classList.remove("active"));
    const navItem = document.querySelector(`.nav-item[data-page="${pageId}"]`);
    if (navItem) navItem.classList.add("active");

    const sidebar = document.getElementById("sidebar");
    if (sidebar.classList.contains("open") && window.matchMedia("(max-width: 1024px)").matches) {
        sidebar.classList.remove("open");
    }

    if (pageId === "dashboard") renderDashboard();
    if (pageId === "topics") renderTopics(getActiveTopicFilter(), getSearchQuery());
    if (pageId === "flashcards") renderFlashcardSetup();
    if (pageId === "trainer") { generateSubnetTask(); generateRaidTask(); }
    
    window.scrollTo({ top: 0 });
}

function showToast(msg, type = "info") {
    const cont = document.getElementById("toastContainer");
    const t = document.createElement("div");
    t.className = `toast ${type}`;
    t.textContent = msg;
    cont.appendChild(t);
    setTimeout(() => t.remove(), 3000);
}

function getStats() {
    let total = 0; let done = 0;
    COURSE_DATA.forEach(t => t.categories.forEach(c => c.lessons.forEach(l => {
        total++;
        if(Storage.isCompleted(l.id)) done++;
    })));
    return { total, done, percent: total ? Math.round((done/total)*100) : 0 };
}

function getSearchQuery() {
    const input = document.getElementById("searchInput");
    return input ? input.value.trim().toLowerCase() : "";
}

function getActiveTopicFilter() {
    return document.querySelector(".chip.active")?.dataset.filter || "all";
}

function activateOnKey(event, callback) {
    if (event.key !== "Enter" && event.key !== " ") return;
    event.preventDefault();
    callback();
}



function renderDashboard() {
    const stats = getStats();
    document.getElementById("heroPercent").textContent = `${stats.percent}%`;
    const offset = 326.73 - (326.73 * stats.percent / 100);
    document.getElementById("heroRingFill").style.strokeDashoffset = offset;
    document.getElementById("statCompleted").textContent = stats.done;
    document.getElementById("statTotal").textContent = stats.total;
    document.getElementById("sidebarProgress").style.width = `${stats.percent}%`;

    const grid = document.getElementById("topicProgressGrid");
    grid.innerHTML = "";
    COURSE_DATA.forEach(topic => {
        let tTotal=0; let tDone=0;
        topic.categories.forEach(c => c.lessons.forEach(l => {
            tTotal++; if(Storage.isCompleted(l.id)) tDone++;
        }));
        let pct = tTotal ? Math.round((tDone/tTotal)*100) : 0;
        grid.innerHTML += `
            <button class="topic-progress-card" type="button" onclick="navigateTo('topics')" style="border-bottom-color: ${pct===100 ? 'var(--success)' : 'transparent'}">
                <div class="tpc-icon" style="background:${topic.color}20; color:${topic.color}">${topic.icon}</div>
                <div class="tpc-title">${topic.title}</div>
                <div style="font-size:0.8rem; color:var(--text-tertiary)">${tDone} von ${tTotal} Lektionen</div>
                <div class="tpc-bar"><div class="tpc-bar-fill" style="width:${pct}%; background:${pct===100 ? 'var(--success)' : topic.color}"></div></div>
            </button>`;
    });
}

function renderTopics(filter="all", rawSearchTerm = "") {
    const list = document.getElementById("topicsList");
    list.innerHTML = "";
    const searchTerm = rawSearchTerm.trim().toLowerCase();

    COURSE_DATA.forEach(topic => {
        const topicMatches = topic.title.toLowerCase().includes(searchTerm);
        let html = `<div class="topic-group open">
            <div class="topic-group-header" role="button" tabindex="0">
                <div class="topic-group-icon" style="background:${topic.color}20; color:${topic.color}">${topic.icon}</div>
                <div class="topic-group-title">${topic.title}</div>
            </div><div class="topic-group-body">`;
        
        let hasContent = false;
        topic.categories.forEach(cat => {
            const catMatches = cat.title.toLowerCase().includes(searchTerm);
            let catHtml = `<div class="subtopic-group open"><div class="subtopic-header" role="button" tabindex="0">${cat.title}</div><div class="subtopic-body">`;
            let hasLesson = false;
            cat.lessons.forEach(l => {
                const done = Storage.isCompleted(l.id);
                if(filter === "done" && !done) return;
                if(filter === "open" && done) return;

                const lessonMatches = l.title.toLowerCase().includes(searchTerm);
                const includeBySearch = !searchTerm || topicMatches || catMatches || lessonMatches;
                if(!includeBySearch) return;

                hasLesson = true; hasContent = true;
                catHtml += `
                    <div class="lesson-item" role="button" tabindex="0" onclick="openLesson('${l.id}')" onkeydown="activateOnKey(event, () => openLesson('${l.id}'))">
                        <button class="lesson-checkbox ${done ? 'checked':''}" type="button" onclick="event.stopPropagation(); toggleLesson('${l.id}')" aria-label="Lektion ${done ? "als offen markieren" : "als erledigt markieren"}">✓</button>
                        <div class="lesson-item-info">${l.title}</div>
                    </div>`;
            });
            catHtml += `</div></div>`;
            if(hasLesson) html += catHtml;
        });
        html += `</div></div>`;
        if(hasContent) list.innerHTML += html;
    });

    if (!list.innerHTML) {
        list.innerHTML = `<div class="topic-group"><div class="topic-group-header"><div class="topic-group-title">Keine Treffer gefunden.</div></div></div>`;
    }
}

function setupTopicsAccordion() {
    const topicsList = document.getElementById("topicsList");
    if (!topicsList) return;

    topicsList.addEventListener("keydown", (event) => {
        const header = event.target.closest(".topic-group-header, .subtopic-header");
        if (!header) return;
        activateOnKey(event, () => header.click());
    });

    topicsList.addEventListener("click", (event) => {
        const topicHeader = event.target.closest(".topic-group-header");
        if (topicHeader) {
            const topicGroup = topicHeader.closest(".topic-group");
            if (topicGroup) topicGroup.classList.toggle("open");
            return;
        }

        const subtopicHeader = event.target.closest(".subtopic-header");
        if (subtopicHeader) {
            const subtopicGroup = subtopicHeader.closest(".subtopic-group");
            if (subtopicGroup) subtopicGroup.classList.toggle("open");
        }
    });
}

function toggleLesson(id) {
    Storage.toggleLesson(id);
    renderTopics(getActiveTopicFilter(), getSearchQuery());
    renderDashboard();
}

function exportProgress() {
    const payload = {
        app: "ap2-master",
        exportedAt: new Date().toISOString(),
        data: Storage.data
    };
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    const datePart = new Date().toISOString().slice(0, 10);
    link.download = `ap2-master-progress-${datePart}.json`;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
    showToast("Fortschritt wurde exportiert.", "success");
}

async function importProgress(file) {
    if (!file) return;
    try {
        const text = await file.text();
        const parsed = JSON.parse(text);
        const importedData = parsed?.data ?? parsed;
        Storage.replace(importedData);
        document.documentElement.setAttribute("data-theme", Storage.data.theme);
        renderDashboard();
        renderTopics(getActiveTopicFilter(), getSearchQuery());
        showToast("Fortschritt erfolgreich importiert.", "success");
    } catch {
        showToast("Import fehlgeschlagen: Ungültige JSON-Datei.", "error");
    }
}

function openLesson(id) {
    let lesson, topicTitle;
    COURSE_DATA.forEach(t => t.categories.forEach(c => c.lessons.forEach(l => {
        if(l.id === id) { lesson = l; topicTitle = t.title; }
    })));
    if(!lesson) return;

    const c = lesson.content;
    const isDone = Storage.isCompleted(id);
    document.getElementById("lessonContainer").innerHTML = `
        <div class="lesson-header">
            <div class="lesson-breadcrumb">${topicTitle}</div>
            <div class="lesson-title">${lesson.title}</div>
        </div>
        <div class="lesson-body">
            <div class="lesson-section"><p>${c.description}</p></div>
            <div class="lesson-section"><h3>Wichtige Punkte</h3><ul>${c.keyPoints.map(p=>`<li>${p}</li>`).join("")}</ul></div>
            ${c.examTip ? `<div class="exam-tip"><h4>💡 Prüfungstipp</h4><p>${c.examTip}</p></div>` : ""}
            <div class="lesson-footer">
                <button class="btn ${isDone ? 'btn-secondary' : 'btn-success'}" onclick="toggleLesson('${id}'); openLesson('${id}')">
                    ${isDone ? "Als offen markieren" : "✓ Als erledigt markieren"}
                </button>
            </div>
        </div>
    `;
    document.getElementById("backToTopics").onclick = () => navigateTo("topics");
    
    document.querySelectorAll(".page").forEach(p => p.classList.remove("active"));
    document.getElementById("page-lesson").classList.add("active");
    window.scrollTo(0,0);
}

